{
    "manifest_version": 3,
    "name": "Enformation Redirect",
    "version": "0.4.3",
    "homepage_url": "https://github.com/alexfikl/e-nformation-redirect",
    "description": "Quickly reload pages through Enformation",

    "background": {
        "scripts": ["background.js"]
    },

    "permissions": ["contextMenus", "tabs"],
    "icons": {
        "32": "icons/icon-dark.svg"
    },

    "action": {
        "default_icon": "icons/icon-dark.svg",
        "theme_icons": [
            {
                "light": "icons/icon-light.svg",
                "dark": "icons/icon-dark.svg",
                "size": 16
            },
            {
                "light": "icons/icon-light.svg",
                "dark": "icons/icon-dark.svg",
                "size": 32
            }
        ],
        "default_title": "Reload through Enformation"
    },

    "browser_specific_settings": {
        "gecko": {
            "id": "enformationredirect@extensions.ro",
            "strict_min_version": "110.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    }
}
